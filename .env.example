# ─────────────────────────────────────────────────────────────
# Dar Al-Amirat Operations Portal — environment variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Postgres connection string.
#
# Local development uses the Docker Postgres service in
# docker-compose.yml (user/password/db = daralamirat). Replace the
# whole value with your hosted connection string (e.g. Neon) in other
# environments — nothing else in the app needs to change.
#
#   Local (Docker):
#     postgresql://daralamirat:<password>@localhost:5432/daralamirat?schema=public
#   Hosted (Neon, example):
#     postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://daralamirat:CHANGE_ME@localhost:5432/daralamirat?schema=public"
