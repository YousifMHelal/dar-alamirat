# ─────────────────────────────────────────────────────────────
# Dar Al-Amirat Operations Portal — environment variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# Postgres connection string.
#
# Local development uses the Docker Postgres service in
# docker-compose.yml (user/password/db = daralamirat). Replace the
# whole value with your hosted connection string (e.g. Neon) in other
# environments — nothing else in the app needs to change.
#
#   Local (Docker):
#     postgresql://daralamirat:<password>@localhost:5432/daralamirat?schema=public
#   Hosted (Neon, example):
#     postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://daralamirat:CHANGE_ME@localhost:5432/daralamirat?schema=public"

# ─────────────────────────────────────────────────────────────
# Auth.js (NextAuth v5)
# ─────────────────────────────────────────────────────────────
# Secret used to sign and encrypt the JWT session cookie. Required in
# every environment. Generate a fresh value with:
#   npx auth secret      (or: openssl rand -base64 32)
AUTH_SECRET="CHANGE_ME_run_npx_auth_secret"

# ─────────────────────────────────────────────────────────────
# ZATCA Phase 2 e-Invoicing
# ─────────────────────────────────────────────────────────────
# Sandbox: https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal
# Production: https://gw-fatoora.zatca.gov.sa/e-invoicing/core
ZATCA_BASE_URL="https://gw-fatoora.zatca.gov.sa/e-invoicing/developer-portal"
# 15-digit VAT registration number (required for QR generation)
ZATCA_VAT_NUMBER="300000000000003"
# Registered seller name (must match your VAT certificate)
ZATCA_SELLER_NAME="Dar Al-Amirat"
# Base64 X.509 certificate from ZATCA Fatoora portal (PEM, no headers)
# Obtain by submitting a CSR through the Fatoora portal
ZATCA_CERT="CHANGE_ME_base64_cert"
# Cryptographic Stamp Identifier — issued by ZATCA after certificate onboarding
ZATCA_CSID="CHANGE_ME_csid"

# ─────────────────────────────────────────────────────────────
# WhatsApp Cloud API (Meta Graph API)
# ─────────────────────────────────────────────────────────────
# Bearer token: System User access token from Meta Business Manager
WHATSAPP_TOKEN="CHANGE_ME"
# Phone number ID from WhatsApp Business Manager (not the phone number itself)
WHATSAPP_PHONE_ID="CHANGE_ME"
# Base URL — defaults to https://graph.facebook.com/v20.0
WHATSAPP_BASE_URL="https://graph.facebook.com/v20.0"
# Override recipient for sandbox testing (all messages go here when set)
WHATSAPP_TEST_NUMBER="+966500000000"

# ─────────────────────────────────────────────────────────────
# Tabby (BNPL reconciliation)
# ─────────────────────────────────────────────────────────────
# Both sandbox and production use https://api.tabby.ai/api/v2
TABBY_BASE_URL="https://api.tabby.ai/api/v2"
# sk_test_... for sandbox, sk_live_... for production
TABBY_SECRET_KEY="sk_test_CHANGE_ME"

# ─────────────────────────────────────────────────────────────
# Tamara (BNPL reconciliation)
# ─────────────────────────────────────────────────────────────
# Sandbox: https://api-sandbox.tamara.co
# Production: https://api.tamara.co
TAMARA_BASE_URL="https://api-sandbox.tamara.co"
TAMARA_API_TOKEN="CHANGE_ME"
TAMARA_MERCHANT_ID="CHANGE_ME"

# ─────────────────────────────────────────────────────────────
# Aramex Shipping
# ─────────────────────────────────────────────────────────────
# Sandbox: https://ws.dev.aramex.net/ShippingAPI.V2/Shipping/Service_1_0.svc/JSON
# Production: https://ws.aramex.net/ShippingAPI.V2/Shipping/Service_1_0.svc/JSON
ARAMEX_BASE_URL="https://ws.dev.aramex.net/ShippingAPI.V2/Shipping/Service_1_0.svc/JSON"
ARAMEX_USERNAME="testingAPI@aramex.com"
ARAMEX_PASSWORD="R123456789$$r"
ARAMEX_ACCOUNT_NUMBER="20016"
ARAMEX_ACCOUNT_PIN="0000"
ARAMEX_ACCOUNT_ENTITY="AMM"
ARAMEX_ACCOUNT_COUNTRY_CODE="JO"

# ─────────────────────────────────────────────────────────────
# SMSA Express
# ─────────────────────────────────────────────────────────────
SMSA_BASE_URL="CHANGE_ME_sandbox_url"
SMSA_PASSKEY="Testing1"
SMSA_ACCOUNT_NUMBER="CHANGE_ME"

# ─────────────────────────────────────────────────────────────
# SPL (Saudi Post / Mwaslat)
# ─────────────────────────────────────────────────────────────
# Sandbox: https://api-test.splonline.com.sa
# Production: https://api.splonline.com.sa
SPL_BASE_URL="https://api-test.splonline.com.sa"
SPL_CLIENT_ID="CHANGE_ME"
SPL_CLIENT_SECRET="CHANGE_ME"
SPL_ACCOUNT_NUMBER="CHANGE_ME"

# ─────────────────────────────────────────────────────────────
# Warehouse operations
# ─────────────────────────────────────────────────────────────
# Phone number used on carrier shipment manifests for the sender (warehouse)
WAREHOUSE_PHONE="+966112345678"
